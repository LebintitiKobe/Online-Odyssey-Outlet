{
    "[r]": {
        "editor.formatOnSave": true
    },
    "spellright.language": [
        "en"
    ],
    "spellright.documentTypes": [
        "markdown",
        "latex",
        "plaintext",
        "quarto"
    ],
    "workbench.topActionBar.visible": true,
    "editor.inlineCompletionsAccessibilityVerbose": true,
    "editor.tabCompletion": "off",
    "notebook.defaultFormatter": "Posit.air-vscode",
    "editor.defaultFormatter": "Posit.air-vscode",
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "editor.formatOnSave": true,
    "editor.wordWrap": "on",
    "editor.autoIndentOnPaste": true,
    "workbench.colorTheme": "Default Positron Dark",
    "editor.formatOnPaste": true,
    "kernelSupervisor.connectionTimeout": 130,
    "kernelSupervisor.startupTimeout": 30,
    "terminal.integrated.defaultProfile.linux": null,
    "editor.formatOnType": true,
    "notebook.formatOnCellExecution": true,
    "notebook.formatOnSave.enabled": true
